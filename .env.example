# Copiez ce fichier en ".env" puis remplacez la valeur par votre vraie clé API Groq.
# Obtenez une clé GRATUITE (sans carte bancaire) sur : https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port du serveur (optionnel, 3000 par défaut)
PORT=3000

# Secret de signature des sessions (JWT). Optionnel : s'il est absent, un secret
# fort est généré et conservé automatiquement dans data/jwt-secret.txt.
# En production, définissez-le vous-même (chaîne longue et aléatoire).
JWT_SECRET=

# ---------- Abonnement Stripe ----------
# 3 générations gratuites par compte, puis abonnement obligatoire.
# 1) Clé secrète : https://dashboard.stripe.com/apikeys  (commence par sk_test_ en test)
STRIPE_SECRET_KEY=
# 2) Identifiant du tarif d'abonnement (Produits → votre produit → API ID du prix, price_...)
STRIPE_PRICE_ID=
# 3) Secret de signature du webhook (Développeurs → Webhooks, ou `stripe listen`, whsec_...)
STRIPE_WEBHOOK_SECRET=
# URL publique du site (facultatif ; utile derrière un domaine/proxy pour les redirections)
PUBLIC_URL=

